@startuml ad_07_flow
skinparam dpi 120
skinparam backgroundColor white
skinparam activity {
  BackgroundColor white
  BorderColor black
  FontSize 12
  DiamondBackgroundColor white
  DiamondBorderColor black
  ArrowColor black
}
skinparam note {
  BackgroundColor lightyellow
  BorderColor gray
}
title UC07 — 控制流程：活動圖

|#e8f4fd|開發者|
|#f0f8e8|Interpreter|

|開發者|
start
:撰寫含控制流程語句的程式碼;

|Interpreter|
:走訪 AST，遇到控制流程節點;

if (節點類型 ?) then (if / else)

  :對條件表達式（condition）求值;
  if (條件值 ≠ 0（真）?) then (是)
    :執行 then 分支的語句區塊;
  else (否)
    if (是否有 else 分支 ?) then (是)
      :執行 else 分支的語句區塊;
    endif
  endif

elseif (節點類型 ?) then (while)

  while (對迴圈條件求值，結果 ≠ 0 ?) is (真)
    :執行迴圈本體;
    if (遇到 break ?) then (是)
      :拋出 BreakException;
      note right: while 捕獲\nBreakException\n正常跳出
      break
    elseif (遇到 continue ?) then (是)
      :拋出 ContinueException;
      note right: while 捕獲\nContinueException\n繼續下一輪
    endif
  endwhile (假)

elseif (節點類型 ?) then (for)

  :執行初始化語句（init）;
  while (對條件求值，結果 ≠ 0 ?) is (真)
    :執行迴圈本體;
    if (遇到 break ?) then (是)
      :拋出 BreakException，跳出迴圈;
      break
    elseif (遇到 continue ?) then (是)
      :拋出 ContinueException，跳至 update;
    endif
    :執行更新語句（update）;
  endwhile (假)

elseif (節點類型 ?) then (do-while)

  repeat
    :執行迴圈本體;
    if (遇到 break ?) then (是)
      :拋出 BreakException，跳出迴圈;
      break
    endif
  repeat while (對後置條件求值，結果 ≠ 0 ?) is (真)

elseif (節點類型 ?) then (switch)

  :對 switch 表達式求值，得到整數 v;
  :依序比對各 case 標籤;
  if (找到匹配的 case ?) then (是)
    :從匹配的 case 開始執行;
    while (還有後續 case 或 default ?) is (是)
      :執行當前 case 程式碼（fall-through）;
      if (遇到 break ?) then (是)
        :拋出 BreakException，跳出 switch;
        break
      endif
    endwhile (否)
  else (否)
    if (有 default 分支 ?) then (是)
      :執行 default 程式碼;
    endif
  endif

else (break / continue 在迴圈 / switch 外)

  :拋出 BreakException / ContinueException;
  :例外向上傳播，無迴圈捕獲;
  :顯示「Runtime error: 'break' outside loop」; <<#ffcccc>>
  stop

endif

|開發者|
:控制流程執行完畢，繼續後續程式碼;
stop

@enduml
