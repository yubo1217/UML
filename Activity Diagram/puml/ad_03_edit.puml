@startuml ad_03_edit
skinparam dpi 120
skinparam backgroundColor white
skinparam activity {
  BackgroundColor white
  BorderColor black
  FontSize 12
  DiamondBackgroundColor white
  DiamondBorderColor black
  ArrowColor black
}
skinparam note {
  BackgroundColor lightyellow
  BorderColor gray
}
title UC03 — 緩衝區編輯：活動圖

|#e8f4fd|使用者|
|#f0f8e8|系統|

|使用者|
start
:輸入緩衝區編輯指令;

|系統|
if (指令類型 ?) then (LIST)

  if (緩衝區是否為空 ?) then (是)
    :顯示「（空緩衝區）」提示;
  else (否)
    :逐行輸出「行號: 內容」;
  endif

elseif (指令類型 ?) then (EDIT <n>)

  :解析行號參數 n;
  if (n 是否為合法整數 ?) then (否)
    :顯示「Usage: EDIT <line_number>」; <<#ffcccc>>
  elseif (n 是否在有效範圍內 ?) then (否)
    :顯示「Line N out of range (1-M)」\n（緩衝區不變）; <<#ffcccc>>
  else (是)
    :顯示第 n 行現有內容;
    |使用者|
    :輸入新的程式碼內容;
    |系統|
    :以新內容取代緩衝區第 n 行;
    :顯示「Line N updated」;
  endif

elseif (指令類型 ?) then (DELETE <n>)

  :解析行號參數 n;
  if (n 是否為合法整數 ?) then (否)
    :顯示「Usage: DELETE <line_number>」; <<#ffcccc>>
  elseif (n 是否在有效範圍內 ?) then (否)
    :顯示「Line N out of range (1-M)」\n（緩衝區不變）; <<#ffcccc>>
  else (是)
    :從緩衝區刪除第 n 行;
    :顯示「Line N deleted」;
  endif

elseif (指令類型 ?) then (INSERT <n>)

  :解析行號參數 n;
  if (n 是否為合法整數 ?) then (否)
    :顯示「Usage: INSERT <line_number>」; <<#ffcccc>>
  elseif (n 是否在有效範圍內 ?) then (否)
    :顯示「Line N out of range」; <<#ffcccc>>
  else (是)
    |使用者|
    :輸入要插入的新程式碼內容;
    |系統|
    :在第 n 行之前插入新行;
    :顯示「Line inserted at N」;
  endif

else (CLEAR)

  :清除終端機畫面（os.system clear）;
  note right: 不影響緩衝區內容

endif

|使用者|
:繼續操作或輸入下一道指令;
stop

@enduml
