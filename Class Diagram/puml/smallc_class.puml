@startuml smallc_class
skinparam dpi 70
skinparam backgroundColor white
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor white
  BorderColor #555555
  ArrowColor #333333
  FontSize 11
  HeaderBackgroundColor #ddeeff
}
skinparam abstract {
  BackgroundColor #f0f0f0
  BorderColor #555555
  HeaderBackgroundColor #c8c8c8
}
skinparam packageStyle rectangle
skinparam package {
  BackgroundColor white
  BorderColor #888888
  FontSize 12
}
skinparam note {
  BackgroundColor #ffffdd
  BorderColor #aaaaaa
  FontSize 10
}

title Small-C 互動式直譯器 — 系統類別圖

' ══════════════════════════════════════════
' memory.py
' ══════════════════════════════════════════
package "memory.py" #edfff0 {
  class Memory {
    + data       : list[int]
    + heap_top   : int
    - _alloc_map : dict
    --
    + __init__(size : int = 65536)
    + allocate(size) : int
    + free_to(addr)
    + read(addr) : int
    + write(addr, value)
    + write_char(addr, value)
    + read_string(addr) : str
    + write_string(addr, s)
    + reset()
  }
  note bottom of Memory
    <module>
    int32(v) : int
    截斷為 32 位元有號整數
  end note
}

' ══════════════════════════════════════════
' symtable.py
' ══════════════════════════════════════════
package "symtable.py" #fffde8 {
  class Symbol {
    + name       : str
    + var_type   : str
    + addr       : int
    + is_pointer : bool
    + is_array   : bool
    + array_size : int
    --
    + __repr__() : str
  }
  class SymbolTable {
    + scopes : list[dict]
    --
    + __init__(memory)
    + push_scope() / pop_scope()
    + is_global() : bool
    + declare(name, var_type, is_pointer) : Symbol
    + declare_array(name, var_type, size) : Symbol
    + lookup(name) : Symbol
    + lookup_or_none(name) : Symbol
    + get_value(name) : int
    + set_value(name, value)
    + get_all_globals() : dict
    + reset()
  }
  SymbolTable "1" *-- "0..*" Symbol : scopes[]
}

' ══════════════════════════════════════════
' builtins.py
' ══════════════════════════════════════════
package "builtins.py" #fdf0ff {
  class Builtins {
    - _dispatch : dict[str, Callable]
    --
    + __init__(memory)
    + call(name, args) : int
    + is_builtin(name) : bool
    .. I/O ..
    - _printf / _putchar / _getchar(args)
    - _puts / _scanf(args)
    .. 字串 ..
    - _strlen / _strcpy / _strcmp / _strcat(args)
    .. 數學 ..
    - _abs / _max / _min / _pow / _sqrt(args)
    - _rand / _srand(args)
    .. 工具 ..
    - _memset / _atoi / _itoa / _exit(args)
  }
}

' ══════════════════════════════════════════
' interpreter.py
' ══════════════════════════════════════════
package "interpreter.py" #fff0f0 {
  class BreakException {
    + trace_repr() : str
  }
  class ContinueException {
    + trace_repr() : str
  }
  class ReturnException {
    + value : int
    --
    + __init__(value)
  }
  class Interpreter {
    + functions  : dict[str, FuncDef]
    + trace_mode : bool
    --
    + __init__()
    + reset()
    + execute(program)
    + execute_interactive(program)
    - _exec_decl(node)
    - _exec_stmt(node)
    - _eval_expr(node) : int
    - _eval_binop(node) : int
    - _eval_unaryop(node) : int
    - _eval_assignment(node) : int
    - _eval_lvalue_read(node) : int
    - _eval_lvalue_write(node, val)
    - _eval_call(node) : int
    - _call_function(name, args) : int
    - _eval_addressof(node) : int
  }
  Interpreter ..> BreakException    : <<throws/catches>>
  Interpreter ..> ContinueException : <<throws/catches>>
  Interpreter ..> ReturnException   : <<throws/catches>>
}

' ══════════════════════════════════════════
' lexer.py
' ══════════════════════════════════════════
package "lexer.py" #eaf4fb {
  class Token {
    + kind  : str
    + value : Any
    + line  : int
    --
    + __repr__() : str
  }
  class Lexer {
    + {static} KEYWORDS   : dict
    + {static} SINGLE_OPS : dict
    + {static} DOUBLE_OPS : dict
    + {static} SYMBOLS    : dict
    - text : str
    - pos  : int
    - line : int
    --
    + __init__(text)
    + tokenize() : Generator[Token]
    - _advance()
    - _peek() : str
    - _character() : Token
    - _string_literal() : Token
    - _number() : Token
    - _identifier() : Token
    - _get_next_token() : Token
  }
  note bottom of Lexer
    <module>
    preprocess(source, defines) : str
    展開 #define 無參數巨集
  end note
  Lexer ..> Token : <<creates>>
}

' ══════════════════════════════════════════
' parser.py — AST 節點
' ══════════════════════════════════════════
package "parser.py  [AST]" #fef9ec {
  class ParseError {
    + msg  : str
    + line : int
  }
  abstract class AST {
    + {abstract} trace_repr() : str
  }
  abstract class Expr {
    + {abstract} __str__() : str
  }
  abstract class Stmt {
    + {abstract} trace_repr() : str
  }
  abstract class Literal {
    + value : Any
  }
  abstract class PointerExpr {
    + {abstract} __str__() : str
  }
  abstract class Decl {
    + name : str
  }
  abstract class LoopStmt {
    + body : Block
  }
  abstract class JumpStmt {
    + trace_repr() : str
  }

  class Number {
    + value : int
  }
  class Char {
    + value : str
  }
  class StringLiteral {
    + value : str
  }
  class Identifier {
    + name : str
  }
  class UnaryOp {
    + op      : str
    + operand : Expr
  }
  class BinOp {
    + left  : Expr
    + op    : str
    + right : Expr
  }
  class Call {
    + name : str
    + args : list[Expr]
  }
  class ArrayAccess {
    + array : str
    + index : Expr
  }
  class Assignment {
    + target : Expr
    + op     : str
    + value  : Expr
  }
  class AddressOf {
    + target : Expr
  }
  class Deref {
    + pointer : Expr
  }
  class VarDecl {
    + var_type   : str
    + name       : str
    + value      : Expr
    + is_pointer : bool
  }
  class ArrayDecl {
    + var_type : str
    + name     : str
    + size     : int
  }
  class FuncDef {
    + ret_type   : str
    + name       : str
    + params     : list
    + is_pointer : bool
    + line       : int
  }
  class Block {
    + statements : list[Stmt]
  }
  class IfStmt {
    + condition   : Expr
    + then_branch : Block
    + else_branch : Block
  }
  class WhileStmt {
    + condition : Expr
    + body      : Block
  }
  class DoWhileStmt {
    + body      : Block
    + condition : Expr
  }
  class ForStmt {
    + init      : Stmt
    + condition : Expr
    + update    : Expr
    + body      : Block
  }
  class SwitchStmt {
    + expr  : Expr
    + items : list
  }
  class Return {
    + value : Expr
  }
  class BreakStmt {
    + trace_repr() : str
  }
  class ContinueStmt {
    + trace_repr() : str
  }
  class ExprStmt {
    + expr : Expr
  }
  class Program {
    + decls : list[AST]
  }

  AST         <|-- Expr
  AST         <|-- Stmt
  AST         <|-- Program
  Expr        <|-- Literal
  Expr        <|-- PointerExpr
  Expr        <|-- Identifier
  Expr        <|-- UnaryOp
  Expr        <|-- BinOp
  Expr        <|-- Call
  Expr        <|-- ArrayAccess
  Expr        <|-- Assignment
  Literal     <|-- Number
  Literal     <|-- Char
  Literal     <|-- StringLiteral
  PointerExpr <|-- AddressOf
  PointerExpr <|-- Deref
  Stmt        <|-- Decl
  Stmt        <|-- LoopStmt
  Stmt        <|-- JumpStmt
  Stmt        <|-- Block
  Stmt        <|-- IfStmt
  Stmt        <|-- SwitchStmt
  Stmt        <|-- ExprStmt
  Decl        <|-- VarDecl
  Decl        <|-- ArrayDecl
  Decl        <|-- FuncDef
  LoopStmt    <|-- WhileStmt
  LoopStmt    <|-- DoWhileStmt
  LoopStmt    <|-- ForStmt
  JumpStmt    <|-- Return
  JumpStmt    <|-- BreakStmt
  JumpStmt    <|-- ContinueStmt

  Program "1" *-- "0..*" AST   : decls
  FuncDef "1" *-- "1"    Block : body
  Block   "1" *-- "0..*" Stmt  : statements
}

' ══════════════════════════════════════════
' parser.py — Parser
' ══════════════════════════════════════════
package "parser.py  [Parser]" #fde8c0 {
  class Parser {
    - tokens  : list[Token]
    - pos     : int
    - current : Token
    --
    + __init__(text)
    + parse() : Program
    - _eat(kind) : Token
    - _peek() : Token
    - _is_func_def() : bool
    - _declaration() : AST
    - _func_def() : FuncDef
    - _var_decl() : Stmt
    - _statement() : Stmt
    - _block() : Block
    - _switch_stmt() : SwitchStmt
    - _assignment() : Expr
    - _logic_or() / _logic_and() : Expr
    - _bit_or() / _bit_xor() / _bit_and() : Expr
    - _equality() / _rel() / _shift() : Expr
    - _add() / _mul() / _unary() / _primary() : Expr
  }
}

' ══════════════════════════════════════════
' repl.py
' ══════════════════════════════════════════
package "repl.py" #f0f0ff {
  class ReplInputCollector {
    - brace_depth : int
    - in_string   : bool
    - in_char     : bool
    --
    + __init__()
    + feed(line) : bool
    + is_complete() : bool
    + reset()
  }
  class REPL {
    + buffer  : list[str]
    - defines : dict
    --
    + __init__()
    + run()
    - _is_command(line) : bool
    - _execute_interactive(source)
    - _handle_command(line)
    - _cmd_load / _cmd_save(parts)
    - _cmd_list / _cmd_edit(parts)
    - _cmd_delete / _cmd_insert(parts)
    - _cmd_append() / _cmd_new()
    - _cmd_run() / _cmd_check()
    - _cmd_trace / _cmd_vars / _cmd_funcs(parts)
    - _cmd_help / _cmd_about / _cmd_quit()
    + {static} _format_runtime(e) : str
  }
  REPL "1" *-- "1" ReplInputCollector : collector
}

' ══════════════════════════════════════════
' main.py
' ══════════════════════════════════════════
package "main.py" #eeeeee {
  class Main <<module>> {
    + {static} main()
  }
}

' ══════════════════════════════════════════
' 跨套件關係
' ══════════════════════════════════════════
SymbolTable  -->  Memory      : uses
Builtins     -->  Memory      : uses
Interpreter "1" *-- "1" Memory      : memory
Interpreter "1" *-- "1" SymbolTable : symtable
Interpreter "1" *-- "1" Builtins    : builtins
Interpreter  ..>  Program     : <<executes>>
Parser       ..>  Lexer       : <<use>>
Parser       ..>  Program     : <<creates>>
REPL      "1" *-- "1" Interpreter  : interpreter
REPL         ..>  Parser      : <<use>>
REPL         ..>  ParseError  : <<catches>>
Main         ..>  REPL        : <<creates>>

@enduml
